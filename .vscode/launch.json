    "version": "0.2.0",
    "configurations": [
        {
            "name": "main full",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["--definitions-file","${workspaceFolder}/data/full.json", "--output-file","${workspaceFolder}/data/topology.png"],
            "console": "integratedTerminal"
        },
        {
            "name": "main mine",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["--definitions-file","${workspaceFolder}/data/mine.json", "--output-file","${workspaceFolder}/data/topology.png"],
            "console": "integratedTerminal"
        },
        {
            "name": "main sub",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["--definitions-file","${workspaceFolder}/data/mine.json", 
                "--substract","${workspaceFolder}/data/full.json",
                "--output-file","${workspaceFolder}/data/topology.png"
                ],
            "console": "integratedTerminal"
        }
    ]
}